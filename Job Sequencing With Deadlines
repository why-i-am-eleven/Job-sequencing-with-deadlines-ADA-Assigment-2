#include <bits/stdc++.h>
using namespace std;

struct Job {
    int id;
    int deadline;
    int profit;
};

// Comparator to sort jobs by profit (descending)
bool compare(Job a, Job b) {
    return a.profit > b.profit;
}

void jobSequencing(Job arr[], int n) {
    // Step 1: Sort jobs by profit
    sort(arr, arr + n, compare);

    // Step 2: Find maximum deadline
    int maxDeadline = 0;
    for (int i = 0; i < n; i++) {
        maxDeadline = max(maxDeadline, arr[i].deadline);
    }

    // Step 3: Create slot array
    vector<int> slot(maxDeadline + 1, -1);

    int totalProfit = 0;
    int countJobs = 0;

    // Step 4: Assign jobs to slots
    for (int i = 0; i < n; i++) {
        for (int j = arr[i].deadline; j > 0; j--) {
            if (slot[j] == -1) {
                slot[j] = arr[i].id;
                totalProfit += arr[i].profit;
                countJobs++;
                break;
            }
        }
    }

    // Output results
    cout << "Number of jobs done: " << countJobs << endl;
    cout << "Total profit: " << totalProfit << endl;

    cout << "Job sequence: ";
    for (int i = 1; i <= maxDeadline; i++) {
        if (slot[i] != -1)
            cout << "J" << slot[i] << " ";
    }
    cout << endl;
}

int main() {
    Job arr[] = {
        {1, 2, 100},
        {2, 1, 19},
        {3, 2, 27},
        {4, 1, 25},
        {5, 3, 15}
    };

    int n = sizeof(arr) / sizeof(arr[0]);

    jobSequencing(arr, n);

    return 0;
}
